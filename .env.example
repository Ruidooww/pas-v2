NODE_ENV=production

PAS_FRONTEND_PORT=18000
PAS_BACKEND_PORT_INTERNAL=3000
PAS_FRONTEND_IMAGE=local/pas-v2/pas-frontend:dev
PAS_BACKEND_IMAGE=local/pas-v2/pas-backend:dev
THROTTLE_LIMIT_PER_MINUTE=120
THROTTLE_LOGIN_LIMIT_PER_MINUTE=10
THROTTLE_QA_LIMIT_PER_MINUTE=30
THROTTLE_MODEL_TEST_LIMIT_PER_MINUTE=5
# Set to 2 only when a separate TLS terminator is in front of pas-frontend.
TRUST_PROXY_HOPS=1

POSTGRES_DB=pas
POSTGRES_USER=pas
POSTGRES_PASSWORD=

REDIS_PASSWORD=
REDIS_URL=
DATABASE_URL=

FILE_STORAGE_DRIVER=local
FILE_STORAGE_ROOT=/data/pas-files
EXPORT_TEMPLATE_ROOT=/data/pas-files/export-templates/v0
EXPORT_TEMPLATE_VERSION=v0-unconfigured

# Required when NODE_ENV=production.
JWT_SECRET=
JWT_EXPIRES_IN_SECONDS=28800
COOKIE_SECURE=true
AUTH_BOOTSTRAP_ADMIN_USERNAME=
AUTH_BOOTSTRAP_ADMIN_PASSWORD=
AUTH_BOOTSTRAP_ADMIN_DISPLAY_NAME=

FEISHU_BOT_ENABLED=false
FEISHU_WEBHOOK_SECRET=

CRM_CLIENT_MODE=mock
CUSTOMER_ANALYSIS_TOP_K=5

# Docker containers should use host.docker.internal to reach the existing host RAGFlow stack.
# If the backend runs directly on Windows, use http://localhost:19380 instead.
RAGFLOW_BASE_URL=http://host.docker.internal:19380
RAGFLOW_CLIENT_MODE=real
RAGFLOW_KEYWORD_ENABLED=true
RAGFLOW_FALLBACK_QUERY_PREFIX=IP-Guard
RAGFLOW_API_KEY=
PAS_KB_ID=
QA_KB_ID=
QA_TOP_K=5

# LLM provider (Bailian/DashScope compatible-mode). mock = no external calls.
# Required to encrypt API keys saved from the AI model access page. Use a base64-encoded 32-byte key.
MODEL_CONFIG_ENCRYPTION_KEY=
# Comma-separated exact host[:port] entries for edited provider URLs and custom endpoints. No wildcards.
MODEL_ENDPOINT_ALLOWLIST=
LLM_CLIENT_MODE=mock
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-max
LLM_TIMEOUT_MS=30000
